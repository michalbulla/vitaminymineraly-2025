{% extends "_layouts/base" %}
{% set uri = entry.uri|default('blog') %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}

{% set showSidebar = false %}

{% block pageLayout %}
  {% embed '_layouts/page/default' %}
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}

        {% block mainContent %}
          {% cache %}
            <h1 class="main-heading">{{ pageHeading }}</h1>
            {{ entry.kratkyPopis }}
            

            {# Main eShop Categories #}
            {# {% set kategorie = craft.categories.group('kategorie').level(1) %}
            {% if kategorie|length %}
              {% for kategoria in kategorie.all() %}
                <h2>{{ kategoria.title }}</h2>
                <div class="grid">
                  {% for child in kategoria.descendants.all() %}
                    <div class="grid-block">
                      {% if child.obrazok|length %}
                        <div class="grid-image">
                          <a href="{{ child.url }}">
                            <img src="{{ child.obrazok.one.url('obrazok') }}" alt="{{ child.obrazok.title }}">
                          </a>
                        </div>
                      {% endif %}
                      <h2><a href="{{ child.url }}">{{ child.title }}</a></h2>
                    </div>
                  {% endfor %}
                </div>
              {% endfor %}
            {% endif %} #}

            {# Main Content #}
            <div class="default-content">
              {% include '_partials/contentBuilder' with {contentField: entry.mainContent, blocksDir: 'mainContent'} %}
            </div>

            {# Aminokyseliny #}
            {% set aminokyseliny = craft.entries.section('pages').id(16105).one %}
            {% if aminokyseliny %}
              {% set aminokyselinyArticles = aminokyseliny.getChildren.limit(12) %}
            {% endif %}
            {% if aminokyselinyArticles is defined and aminokyselinyArticles|length %}
              <div class="default-content">
                <h2>Aminokyseliny</h2>
              </div>
              <div class="grid-cols-2 gap-6 py-6 sm:grid lg:grid-cols-3 md:mx-0">
                {% for article in aminokyselinyArticles %}
                  <div class="grid-block">
                    <div class="grid-image">
                      <a href="{{ article.url }}">
                        <picture class="img-responsive">
                          <source srcset="{{ article.image.one.url('obrazok') }}" type="image/webp">
                          <source srcset="{{ article.image.one.url('obrazok') }}" type="image/jpeg"> 
                          <img src="{{ article.image.one.url('obrazok') }}" alt="{{ article.image.one.title }}">
                        </picture>
                      </a>
                    </div>
                    <div class="grid-copy">
                      <h2 class="text-center font-bold text-2xl text-brand-one mt-2"><a href="{{ article.url }}">{{ article.pageHeading|length ? article.pageHeading : article.title }}</a></h2>
                    </div>
                  </div>
                {% endfor %}
              </div>
              <a class="btn mx-auto w-max block" href="{{ '{entry:18168:url}' | parseRefs }}">Ďalšie {{ '{entry:18168:title}' | parseRefs }}</a>
              <hr/><hr/>
            {% endif %}

            {# Enzýmy #}
            {% set enzymy = craft.entries.section('pages').id(14567).one %}
            {% set articles = enzymy.getChildren.limit(12) %}
            <div class="default-content">
              <h2>Enzýmy</h2>
            </div>
            <div class="grid-cols-2 gap-6 py-6 sm:grid lg:grid-cols-3 md:mx-0">
              {% for article in articles %}
