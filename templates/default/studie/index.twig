{% extends "_layouts/base" %}
{% set uri = entry.uri|default('blog') %}
{% set pageHeading = 'Štúdie' %}

{% set showSidebar = false %}

{% block pageLayout %}
  {% embed '_layouts/page/default' %}
    {% block subNavMobile %}{% endblock %}
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}

        {% block mainContent %}
          {% cache %}
            <h1 class="main-heading">{{ pageHeading }}</h1>
            
            {% paginate craft.entries.section('studie').limit(10) as paginate, articles %}
            <div class="list default-content">
              {% for article in articles %}
                <div class="list-block border-b border-content-divider pb-2 mb-4">
                  <div class="list-copy">
                    <h2><a href="{{ article.url }}">{{ article.pageHeading|length ? article.pageHeading : article.title }}</a></h2>
                    <p>{{ article.kratkyPopis }}</p>
                  </div>
                </div>
              {% endfor %}
            </div>
            {% include '_partials/nav/pagination' with {
              'paginate': paginate,
              'distance': 3,
              'ariaLabel': 'Štúdie'
            } only %}
          {% endcache %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}
