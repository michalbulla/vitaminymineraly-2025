{% extends "_layouts/base" %}
{% set uri = category.uri|default('blog') %}
{% set pageHeading = category.pageHeading|default(category.title) %}

{% set showSidebar = false %}

{% block pageLayout %}
  {% embed '_layouts/page/default' %}
    {% block subNavMobile %}
      
    {% endblock %}
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}

        {% block mainContent %}
          {% cache %}
            <h1>{{ pageHeading }}</h1>

            {# Podkategorie #}
            {% if category.descendants|length %}
              <div class="grid">
                {% for child in category.descendants.descendantDist(1).all() %}
                  <div class="grid-block">
                    <h2><a href="{{ child.url }}">{{ child.title }}</a></h2>
                  </div>
                {% endfor %}
              </div>
            {% endif %}
            {% paginate craft.entries.section('produkty').kategoria(category).limit(10) as paginate, products %}
            {% if products|length %}
              <div class="grid">
                {% for child in products %}
                  <div class="grid-block">
                    <div class="grid-image">
                      <a href="{{ child.url }}">
                        <picture class="img-responsive">
                          <source srcset="{{ child.obrazok.one.url('obrazok') }}" type="image/webp">
                          <source srcset="{{ child.obrazok.one.url('obrazokJpeg') }}" type="image/jpeg"> 
                          <img src="{{ child.obrazok.one.url('obrazokJpeg') }}" alt="{{ child.obrazok.one.title }}">
                        </picture>
                      </a>
                    </div>
                    <h2><a href="{{ child.url }}">{{ child.title }}</a></h2>
                    {% set relatedShops = craft.entries.section('obchodProdukt').relatedTo(child) %}
                    {% set randomRelatedShop = random(relatedShops) %}
                    <a href="{{ randomRelatedShop.obchod.one.affiliateCode|length ? randomRelatedShop.obchod.one.affiliateCode ~ '&url=' }}{{ randomRelatedShop.produktUrl }}" target="_blank" class="btn no-arrow text-center">Pozri v obchode</a>
                  </div>
                {% endfor %}
              </div>
              {% include '_partials/nav/pagination' with {
              'paginate': paginate,
              'distance': 3,
              'ariaLabel': 'Produkty'
            } only %}
            {% endif %}
          {% endcache %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}